# ── Paths (Railway volume at /data) ──────────────────────────────────────────
DB_PATH=/data/trades.db
STATE_DIR=/data/state
STARTING_CAPITAL=10000.0

# ── Risk per trade (decimal fraction) ────────────────────────────────────────
GOLD_RISK_PCT=0.010
BTC_RISK_PCT=0.020
SPY_RISK_PCT=0.010
FVG_RISK_PCT=0.010

# ── Telegram (optional) ───────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Service type ─────────────────────────────────────────────────────────────
# worker service: leave blank (default)
# web service:    SERVICE_TYPE=web
SERVICE_TYPE=
